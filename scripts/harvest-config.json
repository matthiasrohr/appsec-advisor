{
  "output": "../plugin/data/appsec-requirements-fallback.yaml",
  "description": "KN Application Security Requirements (ASR)",
  "url": "https://asr.int.kn",
  "request": {
    "timeout_seconds": 15,
    "auth_header_env": "HARVEST_AUTH_TOKEN",
    "extra_headers": {},
    "use_proxy": false,
    "verify_ssl": false
  },
  "defaults": {
    "_comment": "Default values applied to all sources unless overridden per source.",
    "max_pages": 100,
    "requirements_mode": "structured",
    "_requirements_mode_options": [
      "structured — id, url, text, priority per requirement item (default, compact)",
      "full       — structured + page-level intro/context paragraph(s) per category"
    ],
    "blueprints_mode": "full",
    "_blueprints_mode_options": [
      "full    — title, summary, topics + all sections with content (default)",
      "summary — title, summary, topics only (no sections, minimal size)"
    ],
    "section_max_chars": 5000
  },
  "sources": [
    {
      "id": "asr-scg",
      "type": "requirement",
      "mode": "structured",
      "title": "Secure Coding Guidelines",
      "reference_url": "https://asr.int.kn/scg",
      "crawl_url": "https://asr.int.kn/scg"
    },
    {
      "id": "asr-ssdlc",
      "type": "requirement",
      "mode": "structured",
      "title": "Secure Software Lifecycle (SSDLC)",
      "reference_url": "https://asr.int.kn/ssdlc",
      "crawl_url": "https://asr.int.kn/ssdlc"
    },
    {
      "id": "asr-sslm",
      "type": "requirement",
      "mode": "structured",
      "title": "Secure Software Lifecycle Management (SSLM)",
      "reference_url": "https://asr.int.kn/sslm",
      "crawl_url": "https://asr.int.kn/sslm"
    },
    {
      "id": "appsec-blueprints",
      "type": "blueprint",
      "mode": "full",
      "title": "AppSec Blueprints",
      "reference_url": "https://asr.int.kn/blueprints",
      "crawl_url": "https://asr.int.kn/blueprints",
      "section_max_chars": 5000
    }
  ]
}
