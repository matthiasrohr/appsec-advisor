{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appsec-plugin/schemas/fragments/critical-attack-chain.schema.json",
  "title": "Critical Attack Chain fragment",
  "description": "Data-driven attack-chain section. The renderer produces the Mermaid graph block, the 'Key takeaway' paragraph, and the Stage/Finding/Mitigation reference table from this data.",
  "type": "object",
  "required": ["intro", "mermaid", "key_takeaway", "stages"],
  "additionalProperties": false,
  "properties": {
    "intro": {
      "type": "string",
      "minLength": 40,
      "maxLength": 600,
      "description": "One-paragraph intro describing how the diagram is to be read."
    },
    "mermaid": {
      "type": "object",
      "required": ["orientation", "nodes", "edges"],
      "additionalProperties": false,
      "properties": {
        "orientation": { "type": "string", "enum": ["LR", "TD", "TB"] },
        "nodes": {
          "type": "array",
          "minItems": 3,
          "maxItems": 30,
          "items": {
            "type": "object",
            "required": ["id", "label", "class"],
            "additionalProperties": false,
            "properties": {
              "id":    { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "label": { "type": "string", "minLength": 1, "maxLength": 120 },
              "class": { "type": "string", "enum": ["attacker", "crit", "high", "medium", "low", "impact", "system"] }
            }
          }
        },
        "edges": {
          "type": "array",
          "minItems": 2,
          "maxItems": 60,
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "additionalProperties": false,
            "properties": {
              "from":  { "type": "string" },
              "to":    { "type": "string" },
              "label": { "type": "string", "maxLength": 60 }
            }
          }
        }
      }
    },
    "key_takeaway": {
      "type": "string",
      "minLength": 60,
      "maxLength": 800,
      "description": "Paragraph beginning with '**Key takeaway:**'. The renderer auto-prepends that prefix; supply only the content."
    },
    "stages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "description": "Rows of the Stage/Finding/Mitigation reference table.",
      "items": {
        "type": "object",
        "required": ["stage", "findings", "mitigations"],
        "additionalProperties": false,
        "properties": {
          "stage":       { "type": "string", "minLength": 5, "maxLength": 80 },
          "findings":    {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items":     { "type": "string", "pattern": "^[FT]-\\d{3,4}$" }
          },
          "mitigations": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items":     { "type": "string", "pattern": "^M-\\d{3,4}$" }
          }
        }
      }
    }
  }
}
