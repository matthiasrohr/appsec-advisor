      "chains": {
        "sort_key": "severity_desc_then_member_count_desc",
        "chains_ranked": [
          {
            "id": "CC-03",
            "name": "SQL Injection → Credential Dump → Offline Hash Cracking",
            "severity": "Critical",
            "severity_justification": "The keystone is the SQL injection itself — it is directly exploitable against an unauthenticated endpoint and yields immediate DB dump. The weak password hashing (CWE-916) converts the dump into plaintext credentials in minutes on commodity hardware. The SQLi alone is already Critical; the hashing weakness is a severity amplifier that reduces time-to-impact from hours-of-offline-work to minutes.",
            "breach_distance": 1,
            "keystones": [
              "T-001",
              "T-005",
              "T-017",
              "T-025"
            ],
            "contributors": [
              "T-003",
              "T-007",
              "T-009"
            ],
            "members": [
              "T-001",
              "T-003",
              "T-005",
              "T-007",
              "T-009",
              "T-017",
              "T-025"
            ],
            "narrative": "**Keystone:** Unauthenticated SQL injection ({{SQLI_MEMBERS}}) dumps the\nuser credential table in a single request.\n\n**Contributor:** Weak password hashing ({{HASH_MEMBERS}}) reduces brute\nforce to minutes on commodity GPUs. Without the hashing weakness the\nchain still succeeds (SQLi alone is Critical) but recovery of plaintext\npasswords takes longer. Fixing only the hashing does NOT close the chain."
          },
          {
            "id": "CC-01",
            "name": "Stored XSS → Session Theft via localStorage JWT",
            "severity": "Critical",
            "severity_justification": "A stored XSS payload (keystone) CAN exfiltrate the session token in a single request — the attack is one-step, requires no additional attacker privilege, and affects every user who views the infected content. This is distinct from the contributors (missing CSP, PII in localStorage) which amplify the damage but do not individually realise it.",
            "breach_distance": 2,
            "keystones": [
              "T-018",
              "T-037"
            ],
            "contributors": [
              "T-028",
              "T-035"
            ],
            "members": [
              "T-018",
              "T-028",
              "T-035",
              "T-037"
            ],
            "narrative": "**Keystone:** Stored/reflected XSS payloads ({{XSS_MEMBERS}}) inject\nattacker-controlled script into a rendered page. A single payload is\nsufficient to execute arbitrary JavaScript in every visitor's browser.\n\n**Contributors (amplifiers, not individually Critical):** The JWT is\nstored in `localStorage` ({{STORAGE_MEMBERS}}) — the XSS payload can read\nand exfiltrate it with no CSP to block the outbound request\n({{CSP_MEMBERS}}). Fixing any ONE of the three layers reduces the chain's\nseverity; fixing all three closes it."
          },
          {
            "id": "CC-02",
            "name": "Hardcoded Crypto Key → Offline Token Forgery",
            "severity": "Critical",
            "severity_justification": "The keystone is the presence of the RSA private key in public source — this alone enables JWT forgery for any claim. The signature-verification bypass (alg:none) is a redundant attack path: with the hardcoded key the attacker does not need alg:none, and vice versa. Both are keystones because either alone realises the chain.",
            "breach_distance": 1,
            "keystones": [
              "T-002",
              "T-004",
              "T-014"
            ],
            "contributors": [],
            "members": [
              "T-002",
              "T-004",
              "T-014"
            ],
            "narrative": "**Keystone (either realises the chain alone):** The signing key baked\ninto `{{KEY_FILE}}` ({{KEY_MEMBERS}}) is recoverable by any attacker\nreading the repository. The signature-verification path ({{VERIFY_MEMBERS}})\naccepts `alg:none`, a second independent bypass. Either keystone alone\nyields JWT forgery for any identity, including admin."
          },
          {
            "id": "CC-06",
            "name": "Mass Assignment → Self-Promotion to Admin",
            "severity": "Critical",
            "severity_justification": "Mass assignment alone creates a privilege-escalation vector (user can self-assign privileged fields). When combined with missing admin-role enforcement on subsequent endpoints, the escalation becomes full admin takeover via one POST to /api/Users. Both findings are keystones because either alone is Critical in this architecture.",
            "breach_distance": 1,
            "keystones": [
              "T-013",
              "T-019",
              "T-033"
            ],
            "contributors": [],
            "members": [
              "T-013",
              "T-019",
              "T-033"
            ],
            "narrative": "**Keystone (each alone realises the chain):** The registration endpoint\n({{MA_MEMBERS}}) accepts a `role` field in the request body. The missing\nserver-side admin-role guard on privileged routes ({{AUTHZ_MEMBERS}})\nmeans a user with `role: admin` in their JWT is accepted — no further\nvalidation. A single anonymous POST to create a user with `role=admin`\nyields full admin access. Fix either keystone to close the chain."
          }
        ]
      }
