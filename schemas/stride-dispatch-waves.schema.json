{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appsec-advisor/schemas/stride-dispatch-waves.schema.json",
  "title": "Bounded STRIDE dispatch wave plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_fingerprint",
    "manifest_generated_at",
    "concurrency",
    "component_ids",
    "attempts",
    "waves"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "manifest_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "manifest_generated_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "concurrency": {
      "type": "integer",
      "minimum": 1,
      "maximum": 32
    },
    "component_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "attempts": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0,
        "maximum": 5
      },
      "description": "Per-component dispatch attempts. The effective budget is 2 by default and may be raised to at most 5 via APPSEC_STRIDE_MAX_ATTEMPTS, for recovering a component whose structural cause of failure has since been fixed."
    },
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "component_ids"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 1
          },
          "component_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            }
          }
        }
      }
    }
  }
}
