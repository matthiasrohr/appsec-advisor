{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appsec-advisor/schemas/merge-decisions.schema.json",
  "title": "Threat merger decisions",
  "description": "Decision artifact written by appsec-threat-merger and consumed by merge_threats.py finalize.",
  "type": "object",
  "required": ["version", "generated_at", "model", "decisions"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 2 },
    "generated_at": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision" }
    }
  },
  "$defs": {
    "member_indices": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 0 }
    },
    "decision": {
      "type": "object",
      "required": ["group_id", "action", "member_indices", "rationale"],
      "additionalProperties": false,
      "properties": {
        "group_id": { "type": "string", "pattern": "^(G|GE)-[a-f0-9]{8}$" },
        "action": { "enum": ["merge", "keep", "consolidate"] },
        "member_indices": { "$ref": "#/$defs/member_indices" },
        "merge_target_index": { "type": "integer", "minimum": 0 },
        "consolidated_title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120,
          "allOf": [
            {
              "not": {
                "pattern": "(?i)(@0\\.|@1\\.|@2\\.|@3\\.|alg:none|noent:true|bypassSecurityTrustHtml|crypto\\.createHash|eval\\(|models\\.sequelize\\.query|\\(CVE-|express-jwt@0\\.1\\.3|unzipper@0\\.9\\.15|socket\\.io@3\\.1\\.2)"
              }
            }
          ]
        },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 2000 }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "merge" } } },
          "then": {
            "required": ["merge_target_index"],
            "properties": { "member_indices": { "minItems": 2 } }
          }
        },
        {
          "if": { "properties": { "action": { "const": "consolidate" } } },
          "then": {
            "required": ["merge_target_index", "consolidated_title"],
            "properties": { "member_indices": { "minItems": 3 } }
          }
        }
      ]
    }
  }
}
