{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appsec-plugin/schemas/fragments/compound-chains.schema.json",
  "title": "§8.C Compound Attack Chains fragment",
  "description": "Structured data for the §8.C Compound Attack Chains sub-section. Each CC-NN entry lists the keystone findings (the direct exploit vector whose effective severity rises to the chain severity) and contributor findings (amplifiers capped at High). Rendered as a 2-column table plus narrative paragraphs.",
  "type": "object",
  "required": ["intro", "chains"],
  "additionalProperties": false,
  "properties": {
    "intro": {
      "type": "string",
      "minLength": 40,
      "maxLength": 600,
      "description": "One-paragraph intro distinguishing keystones (directly exploit) from contributors (amplify/defense-in-depth fail)."
    },
    "chains": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "title", "compound_severity", "severity_justification", "breach_distance", "mitigates_by_breaking"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CC-\\d{2}$",
            "description": "Chain ID CC-NN (CC-01, CC-02, …)."
          },
          "title": {
            "type": "string",
            "minLength": 5,
            "maxLength": 120,
            "description": "Short arrow-chain title e.g. 'Stored XSS → Session Theft via localStorage JWT'."
          },
          "compound_severity": {
            "type": "string",
            "enum": ["Critical", "High", "Medium", "Low"]
          },
          "severity_justification": {
            "type": "string",
            "minLength": 40,
            "maxLength": 2000
          },
          "breach_distance": {
            "type": "integer",
            "enum": [1, 2, 3],
            "description": "1 = internet anon, 2 = authenticated user, 3 = requires prior compromise / privileged access."
          },
          "keystones": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ref", "label"],
              "additionalProperties": false,
              "properties": {
                "ref":   { "type": "string", "pattern": "^[FT]-\\d{3,4}$" },
                "label": { "type": "string", "minLength": 5, "maxLength": 200 }
              }
            }
          },
          "contributors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ref", "label"],
              "additionalProperties": false,
              "properties": {
                "ref":   { "type": "string", "pattern": "^[FT]-\\d{3,4}$" },
                "label": { "type": "string", "minLength": 5, "maxLength": 200 }
              }
            }
          },
          "mitigates_by_breaking": {
            "type": "string",
            "minLength": 20,
            "maxLength": 2000,
            "description": "Prose listing the mitigation paths that break or reduce the chain."
          },
          "narrative": {
            "type": "string",
            "description": "Optional additional paragraphs rendered under the 2-column table."
          }
        }
      }
    }
  }
}
