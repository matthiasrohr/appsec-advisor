| [{{ m.id }}](#{{ m.id | lower }}) | {{ m.title }} | **{{ m.priority }}** | {{ m.component_list | format_component_list }} | {{ m.addresses | format_mitigation_addresses }} | {{ m.effort }} |
{%- endfor %}
{%- else -%}
