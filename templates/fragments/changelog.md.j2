{#- Changelog table — rendered from threat-model.yaml → changelog[].
    The "Components Re-analyzed" and "Threats" columns are included only
    when at least one entry carries a meaningful value (non-null, non-zero).
    This avoids empty columns on runs that don't record counts. -#}
{%- set ns = namespace(show_components=false, show_threats=false) %}
{%- for entry in changelog %}
{%- set cre = entry.components_reanalyzed_count if entry.components_reanalyzed_count is not none
              else (entry.reanalyzed_components | length if entry.reanalyzed_components else (entry.components_reanalyzed | length if entry.components_reanalyzed else 0)) %}
{%- set tcount = entry.threats_count if entry.threats_count is not none else 0 %}
{%- if cre and cre > 0 %}{%- set ns.show_components = true %}{%- endif %}
{%- if tcount and tcount > 0 %}{%- set ns.show_threats = true %}{%- endif %}
{%- endfor %}
## Changelog

| Version | Date | Mode |{% if ns.show_components %} Components Re-analyzed |{% endif %}{% if ns.show_threats %} Threats |{% endif %} Note |
|---------|------|------|{% if ns.show_components %}------------------------|{% endif %}{% if ns.show_threats %}---------|{% endif %}------|
{%- for entry in changelog %}
{%- set cre = entry.components_reanalyzed_count if entry.components_reanalyzed_count is not none
              else (entry.reanalyzed_components | length if entry.reanalyzed_components else (entry.components_reanalyzed | length if entry.components_reanalyzed else 0)) %}
{%- set tcount = entry.threats_count if entry.threats_count is not none else '-' %}
{%- set sha = (entry.current_sha or entry.commit_sha or '')[:7] %}
{%- set mode_lbl = (entry.mode or 'full') | capitalize %}
{%- set note = entry.note if entry.note else ('Initial assessment' if entry.version == 1 else '-') %}
{%- set note_with_sha = note ~ ' @ ' ~ sha if sha and sha not in note else note %}
| v{{ entry.version }} | {{ entry.date }} | {{ mode_lbl }} |{% if ns.show_components %} {{ cre }} |{% endif %}{% if ns.show_threats %} {{ tcount }} |{% endif %} {{ note_with_sha }} |
{%- endfor %}
