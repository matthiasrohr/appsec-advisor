{#- ### Security Posture at a Glance — diagram half (heading + intro + Mermaid block). -#}
{#- Inputs (data.*):                                                                -#}
{#-   intro_paragraph              — single-paragraph intro string                  -#}
{#-   subgraph_actors              — { header_label, cards: [{id, label, subtitle,  -#}
{#-                                     severity_class, role}] }                    -#}
{#-   subgraph_tiers               — { header_label, cards: [{node_id, name,        -#}
{#-                                     root_causes_line, components_line,          -#}
{#-                                     severity_counts_line, css_class}] }         -#}
{#-   subgraph_impact              — { header_label, cards: [{node_id, label,       -#}
{#-                                     css_class}] }                               -#}
{#-   alignment_edges              — [{src, dst}]   (rendered with `---`,           -#}
{#-                                                  styled transparent)            -#}
{#-   attack_arrows                — [{src, glyph, label, dst}]                     -#}
{#-   consequence_arrows           — [{src, dst}]                                   -#}
{#-   linkstyle_alignment          — [int]                                          -#}
{#-   linkstyle_attacks            — [int]                                          -#}
{#-   linkstyle_consequences       — [int]                                          -#}
{#- NOTE: no section heading here — the renderer emits the combined           -#}
{#- `### Security Posture & Top Threats` heading + `Figure 2` caption before  -#}
{#- this diagram block.                                                       -#}
{{ data.intro_paragraph }}

```mermaid
%%{init: {"flowchart": {"defaultRenderer": "elk", "nodeSpacing": 45, "rankSpacing": 95}} }%%
flowchart LR
    subgraph ACTORS[" "]
        direction TB
        HDR_A["<b>{{ data.subgraph_actors.header_label }}</b>"]:::columnHeader
{%- for card in data.subgraph_actors.cards %}
        {{ card.id }}(["{% if card.fa_icon %}{{ card.fa_icon }} {% endif %}{{ card.label }}"]):::{{ card.severity_class }}
{%- endfor %}
    end

    subgraph TIERS[" "]
        direction TB
        HDR_T["<b>{{ data.subgraph_tiers.header_label }}</b>"]:::columnHeader
{%- for tier in data.subgraph_tiers.cards %}
{%- if tier.cluster_label_lines and tier.cluster_label_lines|length > 0 %}
        {{ tier.node_id }}["{{ tier.header_summary or tier.name }}<br/>{{ tier.cluster_label_lines | join("<br/>") }}"]:::{{ tier.css_class }}
{%- else %}
        {{ tier.node_id }}["{{ tier.name }}<br/>{{ tier.components_line }}"]:::{{ tier.css_class }}
{%- endif %}
{%- endfor %}
    end

    subgraph IMPACT[" "]
        direction TB
        HDR_I["<b>{{ data.subgraph_impact.header_label }}</b>"]:::columnHeader
{%- for imp in data.subgraph_impact.cards %}
        {{ imp.node_id }}[["{{ imp.label }}"]]:::{{ imp.css_class }}
{%- endfor %}
    end

    %% Invisible alignment hints. Two purposes:
    %%   (a) keep per-component alignment edges (e.g. ANON --- SERVER) so the
    %%       forward attack arrows route horizontally without crossing tier
    %%       boxes (the diagram is forward-only: actor → tier → impact, no
    %%       backward relay edges into the actor column);
    %%   (b) chain the three column headers (HDR_A, HDR_T, HDR_I) across
    %%       subgraph boundaries so ELK pins them on the same Y line.
{%- for e in data.alignment_edges %}
    {{ e.src }} --- {{ e.dst }}
{%- endfor %}

    %% Attack arrows
{%- for a in data.attack_arrows %}
    {{ a.src }} ==>|" {{ a.glyph }} {{ a.label }} "| {{ a.dst }}
{%- endfor %}
{%- if data.relay_arrows %}

    %% Relay arrows (client tier → victim; delivery half of victim-targeting paths)
{%- for r in data.relay_arrows %}
    {{ r.src }} ==>|" {{ r.glyph }} {{ r.label }} "| {{ r.dst }}
{%- endfor %}
{%- endif %}

    %% Consequence arrows (tier → business impact, all LR-forward)
{%- for c in data.consequence_arrows %}
    {{ c.src }} -.-> {{ c.dst }}
{%- endfor %}

    %% Subgraph frames invisible — column headers are emitted as the
    %% FIRST node of each subgraph (HDR_A / HDR_T / HDR_I) and pinned
    %% on the same Y line by the cross-subgraph alignment edges above.
    style ACTORS fill:none,stroke:none
    style TIERS  fill:none,stroke:none
    style IMPACT fill:none,stroke:none

    classDef tierClient fill:#f2f2f2,stroke:#424242,color:#111,stroke-width:2px,font-size:12px
    classDef tierApp    fill:#f2f2f2,stroke:#424242,color:#111,stroke-width:2px,font-size:12px
    classDef tierData   fill:#f2f2f2,stroke:#424242,color:#111,stroke-width:2px,font-size:12px

{%- set _actor_classes = data.subgraph_actors.cards | map(attribute='severity_class') | list %}
{% if 'actorAnon' in _actor_classes %}    classDef actorAnon     fill:#f3dada,stroke:#b71c1c,color:#7f0000,stroke-width:2px,font-size:12px
{% endif %}{% if 'actorShopUser' in _actor_classes %}    classDef actorShopUser fill:#e8f1ea,stroke:#2e7d32,color:#1b5e20,stroke-width:2px,font-size:12px
{% endif %}    classDef impact        fill:#0f172a,stroke:#000,color:#fff,stroke-width:3px,font-size:12px

    classDef columnHeader  fill:none,stroke:none,color:#111,font-size:14px

{% if data.linkstyle_alignment %}    linkStyle {{ data.linkstyle_alignment | join(',') }}     stroke:transparent,stroke-width:0px
{% endif %}{% if data.linkstyle_attacks %}    linkStyle {{ data.linkstyle_attacks | join(',') }}     stroke:#b71c1c,stroke-width:3px
{% endif %}{% if data.linkstyle_consequences %}    linkStyle {{ data.linkstyle_consequences | join(',') }}     stroke:#6b7280,stroke-width:1.5px,stroke-dasharray:4
{% endif %}
```
