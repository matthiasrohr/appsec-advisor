{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appsec-plugin/schemas/fragments/architectural-findings.schema.json",
  "title": "§8.D Architectural Findings fragment",
  "description": "Structured data for §8.D Architectural Findings. Each AF-NNN entry describes a systemic design weakness that aggregates multiple code-level findings. Rendered as a description blockquote + 2-column table per AF entry.",
  "type": "object",
  "required": ["intro", "findings"],
  "additionalProperties": false,
  "properties": {
    "intro": {
      "type": "string",
      "minLength": 40,
      "maxLength": 600
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "architectural_theme", "severity", "structural_defect", "target_architecture", "remediation_effort"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AF-\\d{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 5,
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "minLength": 40,
            "maxLength": 1000,
            "description": "One-paragraph description rendered as a blockquote under the heading."
          },
          "architectural_theme": {
            "type": "string",
            "enum": [
              "Separation", "SecretManagement", "DefenseInDepth", "InputValidation",
              "Authorization", "Authentication", "NetworkSegmentation",
              "DataProtection", "AuditLogging", "SupplyChain", "SecureDefaults",
              "LeastPrivilege", "InsecureDesign",
              "AttackSurfaceDesign", "SessionDesign"
            ]
          },
          "severity": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
          "impact":   { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
          "structural_defect": { "type": "string", "minLength": 20, "maxLength": 400 },
          "target_architecture": { "type": "string", "minLength": 20, "maxLength": 400 },
          "remediation_effort": { "type": "string", "enum": ["Low", "Medium", "High"] },
          "aggregates_findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ref", "label"],
              "additionalProperties": false,
              "properties": {
                "ref":   { "type": "string", "pattern": "^[FT]-\\d{3,4}$" },
                "label": { "type": "string", "maxLength": 200 }
              }
            }
          },
          "primary_mitigations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ref", "label"],
              "additionalProperties": false,
              "properties": {
                "ref":   { "type": "string", "pattern": "^M-\\d{3,4}$" },
                "label": { "type": "string", "maxLength": 200 }
              }
            }
          },
          "derived_from": {
            "type": "string",
            "maxLength": 200,
            "description": "Optional back-reference to §7.x that seeded this architectural finding."
          }
        }
      }
    }
  }
}
